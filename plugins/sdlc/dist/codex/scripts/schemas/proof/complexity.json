{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "proof-complexity",
  "allOf": [{ "$ref": "base.json" }],
  "properties": {
    "files_checked": { "type": "integer" },
    "violations": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "file": { "type": "string" },
              "function": { "type": "string" },
              "complexity": { "type": "integer" },
              "max": { "type": "integer" },
              "type": { "const": "cyclomatic_complexity" }
            },
            "required": ["file", "function", "complexity", "max", "type"]
          },
          {
            "type": "object",
            "properties": {
              "file": { "type": "string" },
              "function": { "type": "string" },
              "lines": { "type": "integer" },
              "max": { "type": "integer" },
              "type": { "const": "function_length" }
            },
            "required": ["file", "function", "lines", "max", "type"]
          }
        ]
      }
    }
  },
  "required": ["gate", "sha", "status", "timestamp", "error", "files_checked", "violations"]
}
