{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "proof-dead-code",
  "allOf": [{ "$ref": "base.json" }],
  "properties": {
    "violations": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "type": { "const": "unused_import" },
              "file": { "type": "string" },
              "name": { "type": "string" },
              "line": { "type": "integer" }
            },
            "required": ["type", "file", "name", "line"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "const": "commented_code" },
              "details": { "type": "string" }
            },
            "required": ["type", "details"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "const": "rubocop_dead_code" },
              "file": { "type": "string" },
              "cop": { "type": "string" },
              "line": { "type": "integer" },
              "message": { "type": "string" }
            },
            "required": ["type", "file", "cop", "line", "message"]
          }
        ]
      }
    }
  },
  "required": ["gate", "sha", "status", "timestamp", "error", "violations"]
}
