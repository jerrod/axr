{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "proof-performance",
  "allOf": [{ "$ref": "base.json" }],
  "properties": {
    "summary": {
      "type": "object",
      "properties": {
        "critical": { "type": "integer" },
        "high": { "type": "integer" },
        "medium": { "type": "integer" },
        "advisory": { "type": "integer" }
      },
      "required": ["critical", "high", "medium", "advisory"]
    },
    "findings": { "type": "array" }
  },
  "required": ["gate", "sha", "status", "timestamp", "error", "summary", "findings"]
}
