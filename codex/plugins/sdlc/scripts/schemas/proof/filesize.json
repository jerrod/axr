{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "proof-filesize",
  "allOf": [{ "$ref": "base.json" }],
  "properties": {
    "files_checked": { "type": "integer" },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file": { "type": "string" },
          "lines": { "type": "integer" },
          "max": { "type": "integer" }
        },
        "required": ["file", "lines", "max"]
      }
    }
  },
  "required": ["gate", "sha", "status", "timestamp", "error", "files_checked", "violations"]
}
