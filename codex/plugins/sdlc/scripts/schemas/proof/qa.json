{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "proof-qa",
  "allOf": [{ "$ref": "base.json" }],
  "properties": {
    "message": { "type": "string" },
    "flows_tested": { "type": "integer" },
    "flows_passed": { "type": "integer" },
    "flows_failed": { "type": "integer" },
    "issues": { "type": "array" },
    "recordings": { "type": "array" }
  },
  "required": ["gate", "sha", "status", "timestamp", "error", "message", "flows_tested", "flows_passed", "flows_failed", "issues", "recordings"]
}
