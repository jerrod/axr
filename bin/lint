#!/usr/bin/env bash
# bin/lint — silent on success; failures only in file:line:message format.
#
# Checks:
#   1. shellcheck on all executable bash scripts (bin/, scripts/)
#   2. jq parse on all *.json files
#   3. YAML frontmatter (first line ---, contains description:) on commands/*.md
set -uo pipefail

strip_ansi() { sed 's/\x1b\[[0-9;]*m//g'; }
FAIL=0

# Resolve repo root regardless of CWD.
if ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    cd "$ROOT" || exit 1
fi

# 1. shellcheck on all bash scripts.
while IFS= read -r -d '' f; do
    if ! shellcheck -f gcc -x "$f" 2>&1 | strip_ansi; then
        FAIL=1
    fi
done < <(find bin scripts -type f \( -name '*.sh' -o -perm -u+x \) -print0 2>/dev/null)

# 2. jq parse on all JSON.
while IFS= read -r -d '' f; do
    if ! err="$(jq empty "$f" 2>&1)"; then
        printf '%s:1: %s\n' "$f" "$err" | strip_ansi
        FAIL=1
    fi
done < <(find . -type f -name '*.json' \
             -not -path './.git/*' \
             -not -path './.axr/*' \
             -not -path './.quality/*' \
             -not -path './.therapist/*' \
             -print0 2>/dev/null)

# 3. YAML frontmatter on commands/*.md.
if [ -d commands ]; then
    for f in commands/*.md; do
        [ -f "$f" ] || continue
        if [ "$(head -n1 "$f")" != "---" ]; then
            printf '%s:1: missing YAML frontmatter (first line is not ---)\n' "$f"
            FAIL=1
            continue
        fi
        FM="$(awk 'NR==1 && /^---$/ {inside=1; next} inside && /^---$/ {exit} inside {print}' "$f")"
        if ! printf '%s\n' "$FM" | grep -Eq '^[[:space:]]*description:[[:space:]]*.+'; then
            printf '%s:1: frontmatter missing description: field\n' "$f"
            FAIL=1
        fi
    done
fi

exit $FAIL
