#!/usr/bin/env bash
# bin/validate — structural integrity checks for the agent-plugins marketplace.
# Checks: (1) JSON parses; (2) marketplace manifest; (3) per-plugin validation.
set -uo pipefail

ERRORS=()
pass() { printf '  ✓ %s\n' "$1"; }
fail() { printf '  ✗ %s\n' "$1"; ERRORS+=("$1"); }
section() { printf '\n%s\n' "$1"; }
# sanitize — strip shell-unsafe chars from strings flowing into error output.
sanitize() { printf '%s' "$1" | tr -d "\$()\`\n\r\t<>&|"; }

cd_repo_root() {
    local root
    if root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
        cd "$root" || exit 1
    else
        cd "$(dirname "${BASH_SOURCE[0]}")/.." || exit 1
    fi
}
has_closed_frontmatter() {
    local file="$1"
    [ "$(head -n1 "$file")" = "---" ] || return 1
    awk 'FNR>1 && /^---$/ {found=1; exit} END{exit !found}' "$file"
}
# validate_frontmatter_dir <plugin_name> <label> <root> <name_glob> [mindepth] [maxdepth]
# Asserts closed YAML frontmatter with description: on each *.md (exempts SCHEMA/README).
validate_frontmatter_dir() {
    local plugin_name="$1" label="$2" root="$3" name_glob="$4"
    local mindepth="${5:-}" maxdepth="${6:-}"
    local find_args=(-P "$root")
    [ -n "$mindepth" ] && find_args+=(-mindepth "$mindepth")
    [ -n "$maxdepth" ] && find_args+=(-maxdepth "$maxdepth")
    find_args+=(-type f -not -type l -name "$name_glob")
    local files=() found_any=false f base fm
    while IFS= read -r -d '' f; do
        found_any=true
        base=$(basename "$f")
        case "$base" in SCHEMA.md|README.md) continue ;; esac
        files+=("$f")
    done < <(find "${find_args[@]}" -print0 2>/dev/null)

    if [ ${#files[@]} -eq 0 ]; then
        if $found_any; then
            fail "$plugin_name: $root contains only exempted files (SCHEMA.md/README.md) — no $label files"
        else
            fail "$plugin_name: $root exists but has no $label files"
        fi
        return 0
    fi
    for f in "${files[@]}"; do
        if ! has_closed_frontmatter "$f"; then
            fail "$plugin_name: $f missing or unclosed YAML frontmatter"
            continue
        fi
        fm=$(awk 'NR==1 && /^---$/ {inside=1; next} inside && /^---$/ {exit} inside {print}' "$f")
        if printf '%s\n' "$fm" | grep -Eq '^[[:space:]]*description:[[:space:]]*.+'; then
            pass "$plugin_name: $f frontmatter has description"
        else
            fail "$plugin_name: $f frontmatter missing description:"
        fi
    done
}
cd_repo_root
REPO_ROOT_REAL="$(pwd -P)" || { printf 'bin/validate: fatal: pwd -P failed\n' >&2; exit 1; }
[ -n "$REPO_ROOT_REAL" ] || { printf 'bin/validate: fatal: REPO_ROOT_REAL is empty\n' >&2; exit 1; }

# --- Check 1: All *.json files parse ---
section "Check 1: JSON files parse"
JSON_FILES=()
while IFS= read -r -d '' f; do
    JSON_FILES+=("$f")
done < <(find -P . -type f -name '*.json' \
             -not -path './.git/*' \
             -not -path './.axr/*' \
             -not -path './.quality/*' \
             -not -path './.therapist/*' \
             -not -path './node_modules/*' \
             -print0 2>/dev/null)

if [ ${#JSON_FILES[@]} -eq 0 ]; then
    fail "no JSON files found"
else
    for f in "${JSON_FILES[@]}"; do
        if jq empty "$f" >/dev/null 2>&1; then
            pass "parses: $f"
        else
            fail "invalid JSON: $f"
        fi
    done
fi

# --- Check 2: marketplace manifest ---
section "Check 2: marketplace manifest"
MARKETPLACE=".claude-plugin/marketplace.json"
if [ ! -f "$MARKETPLACE" ]; then
    fail "$MARKETPLACE missing"
else
    for field in name owner plugins version; do
        if jq -e --arg f "$field" 'has($f)' "$MARKETPLACE" >/dev/null 2>&1; then
            pass "marketplace.json has .$field"
        else
            fail "marketplace.json missing .$field"
        fi
    done
    if jq -e '.plugins | type == "array" and length > 0' "$MARKETPLACE" >/dev/null 2>&1; then
        pass "marketplace.json .plugins is non-empty array"
    else
        fail "marketplace.json .plugins must be a non-empty array"
    fi
    # Every entry needs name, description, source, category, and relative source.
    BAD_ENTRIES=$(jq -r '[.plugins[] | select((has("name")|not) or (has("description")|not) or (has("source")|not) or (has("category")|not) or (.source | startswith("./") | not)) | .name // "<no-name>"] | join(",")' "$MARKETPLACE")
    BAD_ENTRIES=$(sanitize "$BAD_ENTRIES")
    if [ -z "$BAD_ENTRIES" ]; then
        pass "every plugin entry has name, description, source, category, relative source"
    else
        fail "plugin entries with missing fields or non-relative source: $BAD_ENTRIES"
    fi
fi

# --- Check 3: per-plugin validation ---
PLUGIN_DIRS=()
for d in plugins/*/; do
    [ -d "$d" ] || continue
    plugin_real="$(cd "$d" 2>/dev/null && pwd -P)" || continue
    case "$plugin_real" in
        "$REPO_ROOT_REAL"/*) : ;;
        *)
            section "Check 3: ${d%/}"
            fail "${d%/} resolves outside repo root ($plugin_real) — skipping"
            continue
            ;;
    esac
    PLUGIN_DIRS+=("${d%/}")
done
if [ ${#PLUGIN_DIRS[@]} -eq 0 ]; then
    section "Check 3: per-plugin validation"
    fail "no plugins/ subdirectories found"
else
    plugin_idx=0
    for plugin_dir in "${PLUGIN_DIRS[@]}"; do
        plugin_idx=$((plugin_idx + 1))
        plugin_name=$(basename "$plugin_dir")
        section "Check 3/$plugin_idx ($plugin_name)"

        # 3a. plugin.json required fields
        plugin_json="$plugin_dir/.claude-plugin/plugin.json"
        if [ ! -f "$plugin_json" ]; then
            fail "$plugin_name: $plugin_json missing"
        else
            for field in name version description; do
                if jq -e --arg f "$field" 'has($f)' "$plugin_json" >/dev/null 2>&1; then
                    pass "$plugin_name: plugin.json has .$field"
                else
                    fail "$plugin_name: plugin.json missing .$field"
                fi
            done
        fi

        # 3b. Entry-point requirement — need at least one of commands/, skills/, agents/.
        has_commands=false; has_skills=false; has_agents=false
        [ -d "$plugin_dir/commands" ] && has_commands=true
        [ -d "$plugin_dir/skills" ]   && has_skills=true
        [ -d "$plugin_dir/agents" ]   && has_agents=true
        if ! $has_commands && ! $has_skills && ! $has_agents; then
            fail "$plugin_name: no entry point — need at least one of commands/, skills/, agents/"
        fi

        # 3c. commands/ (optional) — flat *.md with description: frontmatter.
        if $has_commands; then
            validate_frontmatter_dir "$plugin_name" "command" \
                "$plugin_dir/commands" '*.md' '' 1
        fi

        # 3d. skills/ (optional) — skills/<name>/SKILL.md with description: frontmatter.
        if $has_skills; then
            validate_frontmatter_dir "$plugin_name" "skill" \
                "$plugin_dir/skills" 'SKILL.md' 2 2
        fi

        # 3e. agents/ (optional) — flat or nested layouts, SCHEMA/README exempt.
        if $has_agents; then
            validate_frontmatter_dir "$plugin_name" "agent" \
                "$plugin_dir/agents" '*.md'
        fi

        # 3f. scripts/ (optional) — every *.sh must be executable.
        if [ -d "$plugin_dir/scripts" ]; then
            SH_FILES=()
            while IFS= read -r -d '' f; do
                SH_FILES+=("$f")
            done < <(find -P "$plugin_dir/scripts" -type f -not -type l -name '*.sh' -print0 2>/dev/null)

            if [ ${#SH_FILES[@]} -eq 0 ]; then
                fail "$plugin_name: scripts/ exists but has no *.sh files"
            else
                for f in "${SH_FILES[@]}"; do
                    if [ -x "$f" ]; then
                        pass "$plugin_name: $f executable"
                    else
                        fail "$plugin_name: $f not executable"
                    fi
                done
            fi
        fi

        # 3g. plugin-local validate hook — refuse symlinks, containment-check parent.
        plugin_validate="$plugin_dir/bin/validate"
        if [ -L "$plugin_validate" ]; then
            fail "$plugin_name: bin/validate is a symlink — refusing to execute"
        elif [ -f "$plugin_validate" ] && [ -x "$plugin_validate" ]; then
            pv_parent_real="$(cd "$(dirname "$plugin_validate")" 2>/dev/null && pwd -P)" || pv_parent_real=""
            case "$pv_parent_real" in
                "$REPO_ROOT_REAL"/*)
                    if timeout 60 "$plugin_validate"; then
                        pass "$plugin_name: plugin-local validate passed"
                    else
                        fail "$plugin_name: plugin-local validate failed or timed out (60s limit)"
                    fi
                    ;;
                *)
                    fail "$plugin_name: bin/validate parent dir resolves outside repo root — skipping"
                    ;;
            esac
        fi

        # 3h. Codex platform checks — if plugin claims codex support,
        # verify dist/codex/ exists, is not stale, and has valid artifacts.
        if [ -f "$plugin_json" ]; then
            codex_status=$(jq -r '.platforms.codex.status // "none"' "$plugin_json" 2>/dev/null)
            case "$codex_status" in
                skill-compatible|hook-dependent)
                    codex_dist="$plugin_dir/dist/codex"
                    build_stamp="$codex_dist/.build-stamp"
                    if [ ! -d "$codex_dist" ]; then
                        fail "$plugin_name: claims codex $codex_status but dist/codex/ missing — run bin/build-codex"
                    elif [ ! -f "$build_stamp" ]; then
                        fail "$plugin_name: dist/codex/ missing .build-stamp — run bin/build-codex"
                    else
                        stale=false
                        if [ -n "$(find -P "$plugin_dir" \
                            \( -path "$plugin_dir/agents/*.md" \
                            -o -path "$plugin_dir/skills/*/SKILL.md" \
                            -o -path "$plugin_dir/commands/*.md" \
                            -o -name "hooks.json" -path "$plugin_dir/hooks/*" \
                            -o -name "plugin.json" -path "$plugin_dir/.claude-plugin/*" \
                            -o -name "codex-hook-overrides.json" -path "$plugin_dir/*" \
                            -o -name "AGENTS.md" -path "$plugin_dir/*" \) \
                            -newer "$build_stamp" -print -quit 2>/dev/null)" ]; then
                            stale=true
                        fi
                        if $stale; then
                            fail "$plugin_name: dist/codex/ is stale — source files changed since last build"
                        else
                            pass "$plugin_name: dist/codex/ exists and is current"
                        fi
                    fi
                    if [ "$codex_status" = "hook-dependent" ]; then
                        readme="$plugin_dir/README.md"
                        if [ -f "$readme" ] && grep -qiE 'codex (limitations|differences)' "$readme"; then
                            pass "$plugin_name: README documents Codex limitations"
                        else
                            fail "$plugin_name: hook-dependent tier requires 'Codex limitations' section in README"
                        fi
                    fi
                    ;;
                unsupported|none) : ;;
                *) fail "$plugin_name: unknown codex status '$codex_status' — must be skill-compatible|hook-dependent|unsupported" ;;
            esac
        fi
    done
fi

# --- Summary ---
printf '\n'
if [ ${#ERRORS[@]} -eq 0 ]; then
    printf 'bin/validate: all checks passed ✓\n'
    exit 0
else
    printf 'bin/validate: %d check(s) failed ✗\n' "${#ERRORS[@]}"
    exit 1
fi
