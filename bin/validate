#!/usr/bin/env bash
# bin/validate — integrity checks for the jerrod/axr marketplace.
#
# Checks:
#   1. Every *.json file parses with jq.
#   2. .claude-plugin/marketplace.json has name + owner + plugins[].
#   3. For each plugin under plugins/*/:
#        a. .claude-plugin/plugin.json has name, version, description, commands.
#        b. If rubric/*.json exists: rubric integrity (weights, criteria, fields).
#        c. Every commands/*.md has closed YAML frontmatter with description:.
#        d. Every scripts/**/*.sh is executable.

set -uo pipefail

cd_repo_root() {
    local root
    if root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
        cd "$root" || exit 1
    elif [ -n "${BASH_SOURCE[1]:-}" ]; then
        cd "$(dirname "${BASH_SOURCE[1]}")/.." || exit 1
    else
        cd "$PWD" || exit 1
    fi
}

has_closed_frontmatter() {
    local file="$1"
    [ "$(head -n1 "$file")" = "---" ] || return 1
    awk 'FNR>1 && /^---$/ {found=1; exit} END{exit !found}' "$file"
}

cd_repo_root

ERRORS=()

pass() { printf '  ✓ %s\n' "$1"; }
fail() { printf '  ✗ %s\n' "$1"; ERRORS+=("$1"); }
section() { printf '\n%s\n' "$1"; }

# ---------------------------------------------------------------------------
# Check 1: All *.json files parse
# ---------------------------------------------------------------------------
section "Check 1: JSON files parse"
JSON_FILES=()
while IFS= read -r -d '' f; do
    JSON_FILES+=("$f")
done < <(find . -type f -name '*.json' \
             -not -path './.git/*' \
             -not -path './.axr/*' \
             -not -path './.quality/*' \
             -not -path './.therapist/*' \
             -not -path './node_modules/*' \
             -print0 2>/dev/null)

if [ ${#JSON_FILES[@]} -eq 0 ]; then
    fail "no JSON files found"
else
    for f in "${JSON_FILES[@]}"; do
        if jq empty "$f" >/dev/null 2>&1; then
            pass "parses: $f"
        else
            fail "invalid JSON: $f"
        fi
    done
fi

# ---------------------------------------------------------------------------
# Check 2: marketplace.json
# ---------------------------------------------------------------------------
section "Check 2: marketplace manifest"
MARKETPLACE=".claude-plugin/marketplace.json"
if [ ! -f "$MARKETPLACE" ]; then
    fail "$MARKETPLACE missing"
else
    for field in name owner plugins; do
        if jq -e --arg f "$field" 'has($f)' "$MARKETPLACE" >/dev/null 2>&1; then
            pass "marketplace.json has .$field"
        else
            fail "marketplace.json missing .$field"
        fi
    done
    if jq -e '.plugins | type == "array" and length > 0' "$MARKETPLACE" >/dev/null 2>&1; then
        pass "marketplace.json .plugins is non-empty array"
    else
        fail "marketplace.json .plugins must be a non-empty array"
    fi
    BAD_ENTRIES=$(jq -r '[.plugins[] | select((has("name")|not) or (has("description")|not) or (has("source")|not) or (.source | startswith("./") | not)) | .name // "<no-name>"] | join(",")' "$MARKETPLACE")
    if [ -z "$BAD_ENTRIES" ]; then
        pass "every plugin entry has name, description, relative source"
    else
        fail "plugin entries with missing fields or non-relative source: $BAD_ENTRIES"
    fi
fi

# ---------------------------------------------------------------------------
# Check 3: per-plugin validation
# ---------------------------------------------------------------------------
PLUGIN_DIRS=()
for d in plugins/*/; do
    [ -d "$d" ] || continue
    PLUGIN_DIRS+=("${d%/}")
done

if [ ${#PLUGIN_DIRS[@]} -eq 0 ]; then
    section "Check 3: per-plugin validation"
    fail "no plugins/ subdirectories found"
else
    for plugin_dir in "${PLUGIN_DIRS[@]}"; do
        plugin_name=$(basename "$plugin_dir")
        section "Check 3: $plugin_name"

        plugin_json="$plugin_dir/.claude-plugin/plugin.json"
        if [ ! -f "$plugin_json" ]; then
            fail "$plugin_name: $plugin_json missing"
        else
            for field in name version description commands; do
                if jq -e --arg f "$field" 'has($f)' "$plugin_json" >/dev/null 2>&1; then
                    pass "$plugin_name: plugin.json has .$field"
                else
                    fail "$plugin_name: plugin.json missing .$field"
                fi
            done
        fi

        RUBRIC_GLOB=("$plugin_dir/rubric/"*.json)
        if [ -e "${RUBRIC_GLOB[0]:-/nonexistent}" ]; then
            for rubric in "${RUBRIC_GLOB[@]}"; do
                [ -f "$rubric" ] || continue
                TOTAL_POINTS=$(jq -r '.total_points // empty' "$rubric")
                if [ "$TOTAL_POINTS" = "100" ]; then
                    pass "$plugin_name: $rubric total_points == 100"
                else
                    fail "$plugin_name: $rubric total_points != 100 (got: ${TOTAL_POINTS:-missing})"
                fi
                WEIGHT_SUM=$(jq -r '(.dimensions | map(.weight) | add) // empty' "$rubric")
                if [ "$WEIGHT_SUM" = "100" ]; then
                    pass "$plugin_name: $rubric weights sum to 100"
                else
                    fail "$plugin_name: $rubric weights sum to ${WEIGHT_SUM:-missing} (expected 100)"
                fi
                BAD_DIMS=$(jq -r '[.dimensions[] | select((.criteria | length) != 5) | .id] | join(",")' "$rubric")
                if [ -z "$BAD_DIMS" ]; then
                    pass "$plugin_name: $rubric every dimension has 5 criteria"
                else
                    fail "$plugin_name: $rubric dimensions without 5 criteria: $BAD_DIMS"
                fi
                BAD_CRIT=$(jq -r '[.dimensions[].criteria[] | select((has("id")|not) or (has("name")|not) or (has("description")|not) or (has("checker_type")|not) or ((.checker_type=="mechanical" or .checker_type=="judgment")|not)) | .id // "<missing-id>"] | join(",")' "$rubric")
                if [ -z "$BAD_CRIT" ]; then
                    pass "$plugin_name: $rubric every criterion has required fields"
                else
                    fail "$plugin_name: $rubric criteria with missing/invalid fields: $BAD_CRIT"
                fi
                BAD_HINTS=$(jq -r '[.dimensions[].criteria[] | select((.evidence_hints | type) != "array" or (.evidence_hints | length) < 1) | .id] | join(",")' "$rubric")
                if [ -z "$BAD_HINTS" ]; then
                    pass "$plugin_name: $rubric every criterion has evidence_hints[] ≥ 1"
                else
                    fail "$plugin_name: $rubric empty/missing evidence_hints: $BAD_HINTS"
                fi
            done
        fi

        if [ -d "$plugin_dir/commands" ]; then
            CMD_FILES=()
            while IFS= read -r -d '' f; do
                CMD_FILES+=("$f")
            done < <(find "$plugin_dir/commands" -maxdepth 1 -type f -name '*.md' -print0 2>/dev/null)

            if [ ${#CMD_FILES[@]} -eq 0 ]; then
                fail "$plugin_name: commands/ has no *.md files"
            else
                for f in "${CMD_FILES[@]}"; do
                    if ! has_closed_frontmatter "$f"; then
                        fail "$plugin_name: $f missing or unclosed YAML frontmatter"
                        continue
                    fi
                    FM=$(awk 'NR==1 && /^---$/ {inside=1; next} inside && /^---$/ {exit} inside {print}' "$f")
                    if printf '%s\n' "$FM" | grep -Eq '^[[:space:]]*description:[[:space:]]*.+'; then
                        pass "$plugin_name: $f frontmatter has description"
                    else
                        fail "$plugin_name: $f frontmatter missing description:"
                    fi
                done
            fi
        fi

        if [ -d "$plugin_dir/scripts" ]; then
            SH_FILES=()
            while IFS= read -r -d '' f; do
                SH_FILES+=("$f")
            done < <(find "$plugin_dir/scripts" -type f -name '*.sh' -print0 2>/dev/null)

            if [ ${#SH_FILES[@]} -eq 0 ]; then
                fail "$plugin_name: scripts/ has no *.sh files"
            else
                for f in "${SH_FILES[@]}"; do
                    if [ -x "$f" ]; then
                        pass "$plugin_name: $f executable"
                    else
                        fail "$plugin_name: $f not executable"
                    fi
                done
            fi
        fi
    done
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
printf '\n'
if [ ${#ERRORS[@]} -eq 0 ]; then
    printf 'bin/validate: all checks passed ✓\n'
    exit 0
else
    printf 'bin/validate: %d check(s) failed ✗\n' "${#ERRORS[@]}"
    exit 1
fi
