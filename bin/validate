#!/usr/bin/env bash
# bin/validate — structural integrity checks for the jerrod/axr marketplace.
#
# Checks:
#   1. Every *.json file parses with jq.
#   2. .claude-plugin/marketplace.json has name + owner + plugins[] with
#      name/description/source/category on every entry, relative sources.
#   3. For each plugin under plugins/*/ (containment-checked against repo root):
#        a. .claude-plugin/plugin.json has name, version, description (Claude
#           Code auto-discovers commands from commands/*.md — no manifest
#           registration needed, and including a `commands` field fails
#           Claude Code's plugin-install schema validation).
#        b. commands/ directory present with at least one *.md, each having
#           closed YAML frontmatter with description:.
#        c. scripts/ directory present with at least one *.sh, all executable.
#        d. If bin/validate exists and is executable, invoke it (plugin-local
#           validation hook — e.g., rubric schema checks).
#        e. If agents/ directory exists, every *.md (except SCHEMA.md/README.md)
#           must have closed YAML frontmatter with a description: field.

set -uo pipefail

cd_repo_root() {
    local root
    if root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
        cd "$root" || exit 1
    else
        cd "$(dirname "${BASH_SOURCE[0]}")/.." || exit 1
    fi
}

has_closed_frontmatter() {
    local file="$1"
    [ "$(head -n1 "$file")" = "---" ] || return 1
    awk 'FNR>1 && /^---$/ {found=1; exit} END{exit !found}' "$file"
}

# sanitize — strip shell-unsafe chars from strings flowing into error output.
sanitize() { printf '%s' "$1" | tr -d "\$()\`"; }

cd_repo_root

REPO_ROOT_REAL="$(pwd -P)" || { printf 'bin/validate: fatal: pwd -P failed\n' >&2; exit 1; }
[ -n "$REPO_ROOT_REAL" ] || { printf 'bin/validate: fatal: REPO_ROOT_REAL is empty\n' >&2; exit 1; }

ERRORS=()

pass() { printf '  ✓ %s\n' "$1"; }
fail() { printf '  ✗ %s\n' "$1"; ERRORS+=("$1"); }
section() { printf '\n%s\n' "$1"; }

# ---------------------------------------------------------------------------
# Check 1: All *.json files parse
# ---------------------------------------------------------------------------
section "Check 1: JSON files parse"
JSON_FILES=()
while IFS= read -r -d '' f; do
    JSON_FILES+=("$f")
done < <(find -P . -type f -name '*.json' \
             -not -path './.git/*' \
             -not -path './.axr/*' \
             -not -path './.quality/*' \
             -not -path './.therapist/*' \
             -not -path './node_modules/*' \
             -print0 2>/dev/null)

if [ ${#JSON_FILES[@]} -eq 0 ]; then
    fail "no JSON files found"
else
    for f in "${JSON_FILES[@]}"; do
        if jq empty "$f" >/dev/null 2>&1; then
            pass "parses: $f"
        else
            fail "invalid JSON: $f"
        fi
    done
fi

# ---------------------------------------------------------------------------
# Check 2: marketplace manifest
# ---------------------------------------------------------------------------
section "Check 2: marketplace manifest"
MARKETPLACE=".claude-plugin/marketplace.json"
if [ ! -f "$MARKETPLACE" ]; then
    fail "$MARKETPLACE missing"
else
    for field in name owner plugins version; do
        if jq -e --arg f "$field" 'has($f)' "$MARKETPLACE" >/dev/null 2>&1; then
            pass "marketplace.json has .$field"
        else
            fail "marketplace.json missing .$field"
        fi
    done
    if jq -e '.plugins | type == "array" and length > 0' "$MARKETPLACE" >/dev/null 2>&1; then
        pass "marketplace.json .plugins is non-empty array"
    else
        fail "marketplace.json .plugins must be a non-empty array"
    fi
    # Every plugin entry must have name, description, source, category, and
    # a source path starting with "./" (relative, within this repo).
    BAD_ENTRIES=$(jq -r '[.plugins[] | select((has("name")|not) or (has("description")|not) or (has("source")|not) or (has("category")|not) or (.source | startswith("./") | not)) | .name // "<no-name>"] | join(",")' "$MARKETPLACE")
    BAD_ENTRIES=$(sanitize "$BAD_ENTRIES")
    if [ -z "$BAD_ENTRIES" ]; then
        pass "every plugin entry has name, description, source, category, relative source"
    else
        fail "plugin entries with missing fields or non-relative source: $BAD_ENTRIES"
    fi
fi

# ---------------------------------------------------------------------------
# Check 3: per-plugin validation (one Check heading per plugin)
# ---------------------------------------------------------------------------
PLUGIN_DIRS=()
for d in plugins/*/; do
    [ -d "$d" ] || continue
    # Symlink containment: resolve real path, skip anything outside repo root.
    plugin_real="$(cd "$d" 2>/dev/null && pwd -P)" || continue
    case "$plugin_real" in
        "$REPO_ROOT_REAL"/*) : ;;
        *)
            section "Check 3: ${d%/}"
            fail "${d%/} resolves outside repo root ($plugin_real) — skipping"
            continue
            ;;
    esac
    PLUGIN_DIRS+=("${d%/}")
done

if [ ${#PLUGIN_DIRS[@]} -eq 0 ]; then
    section "Check 3: per-plugin validation"
    fail "no plugins/ subdirectories found"
else
    plugin_idx=0
    for plugin_dir in "${PLUGIN_DIRS[@]}"; do
        plugin_idx=$((plugin_idx + 1))
        plugin_name=$(basename "$plugin_dir")
        section "Check 3/$plugin_idx ($plugin_name)"

        # 3a. plugin.json required fields
        plugin_json="$plugin_dir/.claude-plugin/plugin.json"
        if [ ! -f "$plugin_json" ]; then
            fail "$plugin_name: $plugin_json missing"
        else
            for field in name version description; do
                if jq -e --arg f "$field" 'has($f)' "$plugin_json" >/dev/null 2>&1; then
                    pass "$plugin_name: plugin.json has .$field"
                else
                    fail "$plugin_name: plugin.json missing .$field"
                fi
            done
        fi

        # 3b. commands/ directory with at least one valid *.md
        if [ ! -d "$plugin_dir/commands" ]; then
            fail "$plugin_name: commands/ directory missing"
        else
            CMD_FILES=()
            while IFS= read -r -d '' f; do
                CMD_FILES+=("$f")
            done < <(find -P "$plugin_dir/commands" -maxdepth 1 -type f -not -type l -name '*.md' -print0 2>/dev/null)

            if [ ${#CMD_FILES[@]} -eq 0 ]; then
                fail "$plugin_name: commands/ has no *.md files"
            else
                for f in "${CMD_FILES[@]}"; do
                    if ! has_closed_frontmatter "$f"; then
                        fail "$plugin_name: $f missing or unclosed YAML frontmatter"
                        continue
                    fi
                    FM=$(awk 'NR==1 && /^---$/ {inside=1; next} inside && /^---$/ {exit} inside {print}' "$f")
                    if printf '%s\n' "$FM" | grep -Eq '^[[:space:]]*description:[[:space:]]*.+'; then
                        pass "$plugin_name: $f frontmatter has description"
                    else
                        fail "$plugin_name: $f frontmatter missing description:"
                    fi
                done
            fi
        fi

        # 3c. scripts/ directory with executable *.sh files
        if [ ! -d "$plugin_dir/scripts" ]; then
            fail "$plugin_name: scripts/ directory missing"
        else
            SH_FILES=()
            while IFS= read -r -d '' f; do
                SH_FILES+=("$f")
            done < <(find -P "$plugin_dir/scripts" -type f -not -type l -name '*.sh' -print0 2>/dev/null)

            if [ ${#SH_FILES[@]} -eq 0 ]; then
                fail "$plugin_name: scripts/ has no *.sh files"
            else
                for f in "${SH_FILES[@]}"; do
                    if [ -x "$f" ]; then
                        pass "$plugin_name: $f executable"
                    else
                        fail "$plugin_name: $f not executable"
                    fi
                done
            fi
        fi

        # 3e. agents/ directory (optional) — if present, every *.md must have
        # closed YAML frontmatter with description: (same rules as commands).
        # SCHEMA.md and other non-agent docs are exempt (no frontmatter expected).
        if [ -d "$plugin_dir/agents" ]; then
            AGENT_FILES=()
            while IFS= read -r -d '' f; do
                AGENT_FILES+=("$f")
            done < <(find -P "$plugin_dir/agents" -maxdepth 1 -type f -not -type l -name '*.md' -print0 2>/dev/null)

            for f in "${AGENT_FILES[@]}"; do
                base=$(basename "$f")
                # Skip docs files that aren't agent definitions.
                case "$base" in
                    SCHEMA.md|README.md) continue ;;
                esac
                if ! has_closed_frontmatter "$f"; then
                    fail "$plugin_name: $f missing or unclosed YAML frontmatter"
                    continue
                fi
                FM=$(awk 'NR==1 && /^---$/ {inside=1; next} inside && /^---$/ {exit} inside {print}' "$f")
                if printf '%s\n' "$FM" | grep -Eq '^[[:space:]]*description:[[:space:]]*.+'; then
                    pass "$plugin_name: $f frontmatter has description"
                else
                    fail "$plugin_name: $f frontmatter missing description:"
                fi
            done
        fi

        # 3d. plugin-local validate hook — refuse symlinks entirely, then
        # containment-check the resolved parent dir. Rejecting symlinked
        # validate files eliminates the symlink-escape bypass and also
        # narrows the TOCTOU window by doing -L + exec back-to-back.
        plugin_validate="$plugin_dir/bin/validate"
        if [ -L "$plugin_validate" ]; then
            fail "$plugin_name: bin/validate is a symlink — refusing to execute"
        elif [ -f "$plugin_validate" ] && [ -x "$plugin_validate" ]; then
            pv_parent_real="$(cd "$(dirname "$plugin_validate")" 2>/dev/null && pwd -P)" || pv_parent_real=""
            case "$pv_parent_real" in
                "$REPO_ROOT_REAL"/*)
                    if "$plugin_validate"; then
                        pass "$plugin_name: plugin-local validate passed"
                    else
                        fail "$plugin_name: plugin-local validate failed (see output above)"
                    fi
                    ;;
                *)
                    fail "$plugin_name: bin/validate parent dir resolves outside repo root — skipping"
                    ;;
            esac
        fi
    done
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
printf '\n'
if [ ${#ERRORS[@]} -eq 0 ]; then
    printf 'bin/validate: all checks passed ✓\n'
    exit 0
else
    printf 'bin/validate: %d check(s) failed ✗\n' "${#ERRORS[@]}"
    exit 1
fi
