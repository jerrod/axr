#!/usr/bin/env bash
# bin/build-codex — generate a self-contained Codex marketplace at repo-root codex/.
#
# Reads tool-mapping.json for name/variable remaps. Iterates plugins/*/ and
# skips any with platforms.codex.status == "unsupported". Transforms skills,
# agents, hooks, commands, and scripts into Codex-compatible format, writes
# each generated plugin to codex/plugins/<name>/, generates a .codex-plugin/
# plugin.json manifest per plugin, and emits the repo-root Codex marketplace
# manifest at codex/.agents/plugins/marketplace.json.
#
# Transform logic lives in bin/lib/build-codex-transforms.sh; manifest and
# marketplace generators live in bin/lib/build-codex-manifests.sh.

set -euo pipefail

cd_repo_root() {
  local root
  if root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    cd "$root" || exit 1
  else
    cd "$(dirname "${BASH_SOURCE[0]}")/.." || exit 1
  fi
}

cd_repo_root

MAPPING_FILE="tool-mapping.json"
if [[ ! -f "$MAPPING_FILE" ]]; then
  echo "ERROR: $MAPPING_FILE not found at repo root" >&2
  exit 1
fi

# shellcheck source=bin/lib/build-codex-transforms.sh
source "bin/lib/build-codex-transforms.sh"
# shellcheck source=bin/lib/build-codex-manifests.sh
source "bin/lib/build-codex-manifests.sh"

CODEX_ROOT="codex"

# Clean old per-plugin dist/codex trees (legacy destination) and the new
# repo-root codex/ tree so every build starts from scratch.
for plugin_dir in plugins/*/; do
  plugin_dir="${plugin_dir%/}"
  rm -rf "$plugin_dir/dist/codex"
done
rm -rf "$CODEX_ROOT"

for plugin_dir in plugins/*/; do
  plugin_dir="${plugin_dir%/}"
  plugin_json="$plugin_dir/.claude-plugin/plugin.json"
  [[ -f "$plugin_json" ]] || continue

  plugin_name=$(jq -r '.name' "$plugin_json")
  # Sanitize: plugin_name flows into a filesystem write path. Refuse anything
  # other than kebab/snake-case identifiers to block traversal or absolute paths.
  if [[ ! "$plugin_name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    echo "ERROR: invalid plugin name '$plugin_name' in $plugin_json (must match [a-zA-Z0-9_-]+)" >&2
    exit 1
  fi
  codex_status=$(jq -r '.platforms.codex.status // "missing"' "$plugin_json")
  if [[ "$codex_status" == "unsupported" ]]; then
    echo "SKIP $plugin_name (unsupported)"
    continue
  fi

  dist_dir="$CODEX_ROOT/plugins/$plugin_name"
  mkdir -p "$dist_dir"
  echo "BUILD $plugin_name"

  transform_skills "$plugin_dir" "$dist_dir"
  transform_agents "$plugin_dir" "$dist_dir"
  transform_hooks "$plugin_dir" "$dist_dir"
  transform_commands "$plugin_dir" "$dist_dir"
  transform_scripts "$plugin_dir" "$dist_dir"
  copy_agents_md "$plugin_dir" "$dist_dir"
  generate_plugin_manifest "$plugin_dir" "$dist_dir"

  # Stamp contents are informational only — staleness is derived from git log
  # commit order of the stamp file itself in bin/lib/validate-codex.sh.
  date -u +%Y-%m-%dT%H:%M:%SZ > "$dist_dir/.build-stamp"
done

generate_marketplace "$CODEX_ROOT"

echo "DONE — $CODEX_ROOT/ built successfully"
