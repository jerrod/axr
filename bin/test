#!/usr/bin/env bash
# bin/test — silent on success; failures only.
#
# Checks:
#   1. bin/validate passes (verbose output suppressed, ✗ lines surfaced)
#   2. Each scripts/check-*.sh exits 0 and emits JSON satisfying invariants:
#        - .dimension_id is a string
#        - .criteria is a non-empty array
#        - every criterion with score >= 2 has non-empty .evidence[]
#        - every criterion with deferred:true has score:null
#        - every criterion has string .id and string .name fields
set -uo pipefail

strip_ansi() { sed 's/\x1b\[[0-9;]*m//g'; }

cd_repo_root() {
    local root
    if root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
        cd "$root" || exit 1
    else
        cd "$(dirname "${BASH_SOURCE[0]}")/.." || exit 1
    fi
}

cd_repo_root

FAIL=0

# 1. bin/validate — run, surface failures in file:line:message format.
#    On non-zero exit, also print the raw output so bash errors that occur
#    before the pass/fail functions fire are not silently swallowed.
if [ -x bin/validate ]; then
    if ! VALIDATE_OUT="$(bin/validate 2>&1 | strip_ansi)"; then
        FAIL=1
        printf '%s\n' "$VALIDATE_OUT"
    else
        # Defensive: if validate exits 0 but emits ✗ lines (internal
        # inconsistency bug), surface them AND mark FAIL so the gate
        # doesn't silently pass.
        if printf '%s\n' "$VALIDATE_OUT" | awk '/✗/ { sub(/^[[:space:]]*✗[[:space:]]*/, ""); print "bin/validate:1: " $0; found=1 } END { exit !found }'; then
            FAIL=1
        fi
    fi
else
    printf 'bin/validate:1: script missing or not executable\n'
    FAIL=1
fi

# 2. checker scripts — exit clean and emit schema-valid JSON.
SCHEMA_FILTER='
    (.dimension_id | type == "string")
    and (.criteria | type == "array")
    and ((.criteria | length) > 0)
    and ([.criteria[] | select((.id | type) != "string" or (.name | type) != "string")] | length == 0)
    and ([.criteria[] | select(.score != null and .score >= 2)
                     | select((.evidence // []) | length < 1)]
         | length == 0)
    and ([.criteria[] | select(.deferred == true and .score != null)] | length == 0)
'

for checker in plugins/*/scripts/check-*.sh; do
    [ -f "$checker" ] || continue
    if ! JSON_OUT="$("$checker" 2>&1)"; then
        printf '%s:1: script exited non-zero\n' "$checker"
        FAIL=1
        continue
    fi
    if ! printf '%s' "$JSON_OUT" | jq -e "$SCHEMA_FILTER" >/dev/null 2>&1; then
        printf '%s:1: output fails schema invariants\n' "$checker"
        FAIL=1
    fi
done

# 3. Codex dist validation — generated TOML parses, hooks.json valid, skills
# have frontmatter, and every generated plugin has a parseable .codex-plugin/
# plugin.json. Runs against the repo-root codex/ tree produced by bin/build-codex.
for codex_dist in codex/plugins/*; do
    [ -d "$codex_dist" ] || continue
    # TOML files parse (basic: no empty name/description)
    for toml_file in "$codex_dist"/agents/*.toml; do
        [ -f "$toml_file" ] || continue
        if ! grep -q '^name[[:space:]]*=' "$toml_file"; then
            printf '%s:1: TOML missing name field\n' "$toml_file"
            FAIL=1
        fi
        if ! grep -q '^description[[:space:]]*=' "$toml_file"; then
            printf '%s:1: TOML missing description field\n' "$toml_file"
            FAIL=1
        fi
    done

    # hooks.json parses
    codex_hooks="$codex_dist/hooks/hooks.json"
    if [ -f "$codex_hooks" ]; then
        if ! jq empty "$codex_hooks" >/dev/null 2>&1; then
            printf '%s:1: invalid JSON\n' "$codex_hooks"
            FAIL=1
        fi
    fi

    # Generated plugin.json parses
    codex_manifest="$codex_dist/.codex-plugin/plugin.json"
    if [ -f "$codex_manifest" ]; then
        if ! jq empty "$codex_manifest" >/dev/null 2>&1; then
            printf '%s:1: invalid JSON\n' "$codex_manifest"
            FAIL=1
        fi
    fi

    # Generated skills have frontmatter
    while IFS= read -r -d '' skill_file; do
        if ! head -n1 "$skill_file" | grep -q '^---$'; then
            printf '%s:1: missing YAML frontmatter\n' "$skill_file"
            FAIL=1
        fi
    done < <(find -P "$codex_dist/skills" -name 'SKILL.md' -print0 2>/dev/null)
done

# 4. Codex marketplace manifest parses.
CODEX_MARKETPLACE="codex/.agents/plugins/marketplace.json"
if [ -f "$CODEX_MARKETPLACE" ]; then
    if ! jq empty "$CODEX_MARKETPLACE" >/dev/null 2>&1; then
        printf '%s:1: invalid JSON\n' "$CODEX_MARKETPLACE"
        FAIL=1
    fi
fi

exit $FAIL
